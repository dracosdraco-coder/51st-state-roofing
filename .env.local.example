# ============================================================================
# 51st State Roofing - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values
# ============================================================================

# ============================================================================
# Google Analytics & Google Tag Manager
# ============================================================================
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Google Places API for address autocomplete in estimator
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# ============================================================================
# Facebook Pixel
# ============================================================================
NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXX

# ============================================================================
# CallRail (Phone Tracking & Number Swapping)
# ============================================================================
NEXT_PUBLIC_CALLRAIL_ACCOUNT_ID=XXXXXXXXXXXXXXX
NEXT_PUBLIC_CALLRAIL_PAID=XXXXXXXXXXXXXXX
NEXT_PUBLIC_CALLRAIL_ORGANIC=XXXXXXXXXXXXXXX

# ============================================================================
# Sanity CMS
# ============================================================================
NEXT_PUBLIC_SANITY_PROJECT_ID=YOUR_SANITY_PROJECT_ID
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=YOUR_SANITY_API_TOKEN

# ============================================================================
# Lead Management
# ============================================================================
# Projex CRM Webhook URL for lead submissions
NEXT_PUBLIC_PROJEX_WEBHOOK_URL=https://api.projexcrm.com/webhooks/leads

# Resend API for transactional emails (optional)
RESEND_API_KEY=YOUR_RESEND_API_KEY

# ============================================================================
# Site Configuration
# ============================================================================
NEXT_PUBLIC_SITE_URL=https://51stateroofing.com

# ============================================================================
# Notes
# ============================================================================
# NEXT_PUBLIC_* variables are exposed to the browser
# Other variables are server-only

# For local development:
# 1. Google Analytics/GTM will still track development
# 2. Projex webhook will send test leads
# 3. Consider using test account IDs for development

# For production:
# 1. Replace all test IDs with production values
# 2. Ensure NEXT_PUBLIC_SITE_URL matches your domain
# 3. Set up proper CORS for Sanity API
